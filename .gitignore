# Backend .gitignore for Node.js
# Dependency directories
node_modules/

# Build / compiled output
dist/
build/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Environment files
.env
.env.*

# OS generated files
.DS_Store
Thumbs.db

# IDE / editor files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Misc
coverage/
.tmp/